[global_config]
  window_state = hidden
  homogeneous_tabbar = False
  hide_from_taskbar = True
[keybindings]
[profiles]
  [[default]]
    show_titlebar = False
    copy_on_selection = True
    # Nerd Font：LazyVim / nvim-web-devicons 图标依赖；需 pacman -S ttf-terminus-nerd
    # font = TerminessTTF Nerd Font 11
    font = JetBrainsMono Nerd Font 11
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
      profile = default
[plugins]
