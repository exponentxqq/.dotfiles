{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/qwen3.7-plus",
  "permission": "allow",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@ephemushroom/opencode-claude-mem",
  ],
  "agent": {
    "plan": {
      "model": "zai-coding-plan/glm-5.2",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
      },
    },
    "build": {
      "model": "deepseek/deepseek-v4-pro",
      "temperature": 0.0,
    },
    "general": {
      "model": "opencode-go/qwen3.7-plus",
      "temperature": 0.1,
    },
    "title": {
      "model": "opencode-go/minimax-m3",
    },
    "compaction": {
      "model": "deepseek/deepseek-v4-flash",
    },
    "summary": {
      "model": "deepseek/deepseek-v4-flash",
    },
    "code-reviewer": {
      "description": "Reviews code for quality, security, and best practices",
      "mode": "subagent",
      "model": "opencode-go/qwen3.7-plus",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny",
      },
    },
  },
  "lsp": {
    "gopls": {
      "command": ["/home/xuqinqin/develop/docker/bin/gopls"],
    },
    "rust": {
      "command": ["/home/xuqinqin/develop/docker/bin/rust-analyzer"],
    },
    "pyright": {
      "disabled": true,
    },
    "jdtls": {
      "command": [
        "/home/xuqinqin/.local/share/nvim/mason/packages/jdtls/bin/jdtls",
      ],
      "env": {
        "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk",
      },
    },
  },
  "mcp": {
    "codebase-memory-mcp": {
      "type": "local",
      "command": ["codebase-memory-mcp"],
    },
    "dbx-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@dbx-app/mcp-server"],
      "environment": {
        "DBX_WEB_URL": "http://localhost:4224",
        "DBX_MCP_SCOPE_CONNECTION_NAME": "localhost@mysql5.7",
      },
    },
  },
}
